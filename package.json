{
  "name": "tk-postral",
  "version": "5.2.0",
  "description": "",
  "author": "",
  "private": true,
  "license": "MIT",
  "repository": {
    "url": "https://github.com/ubs-platform/ubs-mona-mr"
  },
  "docker": {
    "organisation": "hcangunduz",
    "imageNamePrefix": "tk-postral-"
  },
  "iksir": {
    "type": "ROOT",
    "childrenVersionTag": "beta",
    "childrenAccess": "public",
    "childrenPrefix": "@tk-postral"
  },
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "xr": "node ./tools/xr.js",
    "xr:publish-libs": "node ./tools/xr.js publish-libs",
    "xr:patch-libs": "node ./tools/xr.js patch-libs",
    "xr:extend-lib": "node ./tools/xr.js extend-lib",
    "rebuild-xr": "cd ./tools/src && tsc",
    "start": "tools/devserve.sh",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/apps/ubs-mona-mr/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./apps/ubs-mona-mr/test/jest-e2e.json"
  },
  "dependencies": {
    "@blazity/nest-file-fastify": "^1.0.0",
    "@fastify/multipart": "^9.0.3",
    "@fastify/static": "^8.1.1",
    "@msgpack/msgpack": "^3.1.2",
    "@nestjs-modules/mailer": "^2.0.2",
    "@nestjs/common": "11.0.7",
    "@nestjs/core": "11.0.7",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/microservices": "^11.0.7",
    "@nestjs/mongoose": "^11.0.1",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "11.0.7",
    "@nestjs/platform-fastify": "^11.0.11",
    "@nestjs/schedule": "^5.0.1",
    "@nestjs/serve-static": "^5.0.1",
    "@nestjs/typeorm": "^11.0.0",
    "@ubs-platform/crud-base-common": "5.7.1",
    "@ubs-platform/feedback-common": "5.7.1",
    "@ubs-platform/microservice-setup-util": "5.7.1",
    "@ubs-platform/dynamic-queue": "5.7.1",
    "@ubs-platform/notify-common": "5.7.1",
    "@ubs-platform/social-common": "5.7.1",
    "@ubs-platform/superlama-common": "5.7.1",
    "@ubs-platform/translator-core": "^1.0.9",
    "@ubs-platform/translator-ngx": "^4.0.0",
    "@ubs-platform/users-common": "5.7.1",
    "@ubs-platform/users-microservice-helper": "5.7.1",
    "@ubs-platform/users-roles": "5.7.1",
    "axios": "^1.7.9",
    "comment-json": "^4.2.5",
    "crypto-promise": "^2.1.0",
    "kafkajs": "^2.2.4",
    "moment": "^2.30.1",
    "mongoose": "^8.10.2",
    "mysql2": "^3.13.0",
    "ollama": "^0.5.14",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.33.5",
    "typeorm": "^0.3.21"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.10.7",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^15.14.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "types-package-json": "^2.0.39",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "webpack": "5.97.1"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/",
      "<rootDir>/libs/"
    ],
    "moduleNameMapper": {
      "^@tk-postral/payments(|/.*)$": "<rootDir>/libs/payments/src/$1"
    }
  }
}