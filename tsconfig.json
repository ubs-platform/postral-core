{
  "exclude": [
    "./tools"
  ],
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "noFallthroughCasesInSwitch": false,
    "paths": {
      "@tk-postral/payment-common": [
        "libs/payment-common/src"
      ],
      "@tk-postral/payment-common/*": [
        "libs/payment-common/src/*"
      ],
      "@tk-postral/postral-entities": [
        "libs/postral-entities/src"
      ],
      "@tk-postral/postral-entities/*": [
        "libs/postral-entities/src/*"
      ]
    }
  }
}