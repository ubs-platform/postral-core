

# Sürüm numaraları
POSTRAL_CORE_WEB_VERSION=1.0.3-beta
POSTRAL_CORE_API_VERSION=1.0.3-beta
UBS_VERSION=6.9.0
ENGINE5_VERSION=0.0.12-alpha
MONGODB_VERSION=5.0.15
MARIA_DB_VERSION=latest

# Engine5 ortam değişkenleri
E5_PORT=3535
ENABLE_TLS=false
REQUIRE_AUTH=false

# Postral Core API için veritabanı bağlantı bilgileri
POSTRAL_DB_TYPE=mariadb
POSTRAL_DB_HOST=mariadb
POSTRAL_DB_PORT=3306
POSTRAL_DB_NAME=postral_core
POSTRAL_DB_USER=root
POSTRAL_DB_PASSWORD=

# UBS Mona için DB bağlantı bilgileri
NX_MONGO_URL=my-mongodb:27017
NX_MONGO_USERNAME=admin
NX_MONGO_PASSWORD=admin

# Hem UBS Mona hem de Postral Core API için ortak veritabanı bağlantı bilgileri
NX_MICROSERVICE_TYPE=ENGINE5 # MQ Servisi tipini belirtir, örneğin ENGINE5 veya KAFKA
E5_HOST=engine5 # Engine5'in çalıştığı host adı veya IP adresi
E5_PORT=3535 # Engine5'in dinlediği port
NX_SECRET_JWT=23ac43b5e6f2a12 # JWT için gizli anahtar
NX_SECRET_PW=secret # Şifreleme için gizli anahtar

# UBS Mona için yapılandırmalar
UBS_USERS_INITIAL_USERNAME=admin
UBS_USERS_INITIAL_PW=admin
UBS_USERS_INITIAL_EMAIL=admin@localhost
UBS_USERS_INITIAL_NAME=Admin
UBS_USERS_INITIAL_SURNAME=Tetakent
U_USERS_PW_RESET_URL=/password-reset/resolve/:id?from=ubs # Şifre sıfırlama URL'si
U_USERS_REGISTERED_USER_VALIDATING_URL=/login?activationKey=:key # Kayıtlı kullanıcı doğrulama URL'si
UNOTIFY_DEFAULT_LANGUAGE=en-us # Email ve diğer bildirimler için varsayılan dil
UNOTIFY_MAIL_FROM=info@tester.tetakent.com # Unotify tarafından gönderilen maillerin "from" adresi
UNOTIFY_MAIL_SERVER_HOST=localhost # Mail sunucusunun host adı veya IP adresi
UNOTIFY_MAIL_SERVER_PORT=25 # Mail sunucusunun portu
UNOTIFY_MAIL_CERT_IGNORE_SSL=true # SSL sertifikasını yoksay
UBS_PORT=3000 # UBS Mona'nın çalışacağı port

# Postral için yapılandırmalar
POSTRAL_INSTANCE_ID=postral-instance-1 # Postral örneği için benzersiz bir kimlik
POSTRAL_PORT=3767 # Postral Core API'nin çalışacağı port
POSTRAL_LOG_LEVEL=info # Postral Core API için log seviyesi (örneğin